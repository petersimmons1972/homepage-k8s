# Ignore files with sensitive data
.env
*.env
.env.*

# Ignore backup files that might contain secrets
*.bak
*.backup
*~

# Ignore temporary files
*.tmp
*.temp

# Ignore any files with actual secrets (not templates)
*secret.yaml
!*secret-template.yaml
*configmap.yaml
!*configmap-template.yaml

# Ignore domain-specific files
*petersimmons*

# Ignore old backup files
*.yaml-old
*.yaml-not

# Ignore OS generated files
.DS_Store
Thumbs.db

# Ignore personal configuration files
personal-*
*-personal.*
